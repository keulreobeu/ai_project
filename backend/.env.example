# Relative paths are resolved from the repository root. Render persistent disks
# can use an absolute path such as /var/data/seoul_festival.db.
DB_PATH=project/seoul_festival.db
CORS_ORIGINS=http://localhost:5173,https://your-site.netlify.app
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Korea Tourism Organization TourAPI (real keys belong in backend/.env only)
DATA_GO_KR_ENDPOINT=https://apis.data.go.kr/B551011/KorService2
DATA_GO_KR_SERVICE_KEY_ENCODED=
DATA_GO_KR_SERVICE_KEY_DECODED=
